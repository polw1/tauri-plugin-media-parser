{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-media-player",
  "version": "0.1.0",
  "identifier": "com.root.tauri-media-player",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tauri-media-player",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http: blob: memio:; media-src 'self' https: http: blob: memio:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "gstreamer1.0-libav",
          "gstreamer1.0-plugins-good"
        ]
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
